# Hyperliquid — READ-ONLY in v1.
# Account address is used only for fetching public user state (positions, equity) via the Info endpoint.
# DO NOT add a private key. Signing is not implemented in v1.
HL_ACCOUNT_ADDRESS=

# Telegram notifications (optional). Leave blank to disable.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenClaw notification webhook (optional).
OPENCLAW_WEBHOOK_URL=
